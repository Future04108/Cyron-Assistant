# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# Backend API Configuration
BACKEND_URL=http://localhost:8000
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_ticket_assistant

# Redis
REDIS_URL=redis://localhost:6379/0

# Discord OAuth (Dashboard Login)
DISCORD_CLIENT_ID=your_discord_oauth_client_id
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret
DISCORD_OAUTH_SCOPE=identify guilds
# Public backend URL used for OAuth callback
BACKEND_PUBLIC_URL=http://localhost:8000
# Allowed frontend origins for redirect_uri validation (comma-separated)
FRONTEND_ALLOWED_ORIGINS=http://localhost:5173

# App auth token signing
AUTH_JWT_SECRET=change-this-in-production
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_EXP_MINUTES=1440
